# ============================================================
# Six43 – Environment Variables
# ============================================================
# COPY THIS FILE to .env.local and fill in your values.
# NEVER commit .env.local to git. It's already in .gitignore.
#
# WHERE TO FIND THESE VALUES:
#   1. Go to supabase.com → your project
#   2. Click Settings → API
#   3. Copy "Project URL" → NEXT_PUBLIC_SUPABASE_URL
#   4. Copy "anon public" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# The anon key is safe to put in frontend code.
# It looks public but is protected by Row Level Security (RLS).
# NEVER put the service_role key in frontend code.
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — NEVER put these in NEXT_PUBLIC_ vars
# Found in Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The email address allowed to access /admin and manage user plans
ADMIN_EMAIL=you@example.com
